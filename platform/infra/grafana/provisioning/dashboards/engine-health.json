      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(vllm_engine_requests_running)",
