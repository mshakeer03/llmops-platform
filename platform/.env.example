# =============================================================================
#  LLMOps Platform — Environment Variables
#  Copy to .env and adjust values before running:
#    cp .env.example .env
#    podman-compose up --build -d
# =============================================================================

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# Created only if no admin account exists in the DB
SEED_ADMIN_EMAIL=admin@llmops.local
SEED_ADMIN_PASSWORD=changeme

# ── LiteLLM ──────────────────────────────────────────────────────────────────
# Master key for LiteLLM proxy API calls
# Generate with: python -c "import secrets; print('sk-' + secrets.token_hex(24))"
LITELLM_MASTER_KEY=sk-llmops-master-key-change-me

# LiteLLM Admin UI credentials  (UI: http://localhost:4000/ui)
# Required explicitly since LiteLLM v1.40+ — MASTER_KEY alone no longer works
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=llmops-admin

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=llmops-dev

# ── Optional integrations ─────────────────────────────────────────────────────
# Slack webhook for approval/eval alerts
WEBHOOK_URL=

# HuggingFace token (only needed for gated online models)
# HF_TOKEN=hf_...
